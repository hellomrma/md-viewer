{
  "name": "md-viewer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@shikijs/rehype": "1",
    "hast-util-to-string": "3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "9",
    "rehype-autolink-headings": "7",
    "rehype-sanitize": "6",
    "rehype-slug": "6",
    "remark-gfm": "4",
    "shiki": "1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1",
    "@testing-library/jest-dom": "6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "14",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "24",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwindcss": "3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "unified": "^11.0.5",
    "vite": "^8.0.10",
    "vitest": "1"
  }
}
